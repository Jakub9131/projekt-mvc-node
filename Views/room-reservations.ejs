<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rezerwacje - <%= room.name %></title>
    <style>
        :root {
            --primary: #4f46e5;
            --primary-hover: #4338ca;
            --background: #f8fafc;
            --surface: #ffffff;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --danger: #ef4444;
            --danger-hover: #dc2626;
            --amber: #d97706;
            --amber-hover: #b45309;
        }

        body { 
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; 
            margin: 0; 
            padding: 40px; 
            background-color: var(--background); 
            color: var(--text-main);
            line-height: 1.5;
        }

        h1 { font-size: 2rem; font-weight: 700; color: var(--text-main); margin-bottom: 5px; }
        h2 { font-size: 1.25rem; font-weight: 600; color: var(--text-main); margin-top: 35px; margin-bottom: 15px; }
        
        .header-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .back-link { 
            display: inline-flex; 
            align-items: center;
            color: var(--primary); 
            text-decoration: none; 
            font-weight: 600; 
            font-size: 0.95rem;
            transition: color 0.2s;
        }
        .back-link:hover { color: var(--primary-hover); }
        
        .user-panel { 
            background: var(--surface); 
            padding: 10px 18px; 
            border-radius: 10px; 
            font-weight: 600; 
            font-size: 0.9rem;
            border: 1px solid var(--border);
            box-shadow: 0 1px 2px rgba(0,0,0,0.02);
        }
        .user-panel a { color: var(--danger); text-decoration: none; margin-left: 12px; font-weight: 700; }
        .user-panel a:hover { color: var(--danger-hover); }

        .room-info-bar {
            background: #f1f5f9;
            padding: 12px 20px;
            border-radius: 10px;
            margin-bottom: 30px;
            font-size: 0.95rem;
            color: #475569;
            border: 1px solid var(--border);
            display: inline-flex;
            gap: 20px;
        }

        .box { 
            background: var(--surface); 
            padding: 28px; 
            border-radius: 16px; 
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); 
            margin-bottom: 35px; 
            max-width: 500px; 
            border: 1px solid var(--border);
        }
        
        .form-group { margin-bottom: 16px; }
        .form-group label { display: block; margin-bottom: 6px; font-weight: 500; font-size: 0.9rem; }
        .form-group input, .form-group select { 
            width: 100%; padding: 10px 14px; border: 1px solid var(--border); border-radius: 8px; box-sizing: border-box; font-size: 0.95rem; background-color: #fff; transition: border-color 0.2s;
        }
        .form-group input:focus, .form-group select:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1); }
        
        .btn-submit { background: var(--primary); color: white; padding: 12px 20px; border: none; border-radius: 8px; cursor: pointer; font-size: 0.95rem; font-weight: 600; width: 100%; transition: background 0.2s; }
        .btn-submit:hover { background: var(--primary-hover); }

        .error-alert {
            background-color: #fee2e2;
            color: #ef4444;
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 20px;
            border: 1px solid #fca5a5;
        }

        .table-container {
            background: var(--surface); border-radius: 16px; border: 1px solid var(--border); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); overflow: hidden; margin-top: 15px; max-width: 900px;
        }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 16px 20px; text-align: left; font-size: 0.92rem; }
        th { background-color: #f8fafc; color: var(--text-muted); font-weight: 600; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em; border-bottom: 1px solid var(--border); }
        td { border-bottom: 1px solid var(--border); color: var(--text-main); vertical-align: middle; }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background-color: #f8fafc; }

        .btn-action-delete {
            background: #fee2e2; color: var(--danger); padding: 6px 12px; border: none; border-radius: 6px; font-weight: 600; font-size: 0.85rem; cursor: pointer; transition: background 0.2s; width: auto;
        }
        .btn-action-delete:hover { background: #fca5a5; }
        
        .btn-action-edit {
            background: #fef3c7; color: #b45309; padding: 6px 12px; border: none; border-radius: 6px; font-weight: 600; font-size: 0.85rem; cursor: pointer; transition: background 0.2s; width: auto;
        }
        .btn-action-edit:hover { background: #fde68a; }
    </style>
</head>
<body>

    <div class="header-container">
        <a href="/" class="back-link">⬅️ Powrót do listy sal</a>
        
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
            <div class="user-panel">
                👤 Zalogowany: <%= currentUser.firstName %> <%= currentUser.lastName %> 
                <a href="/auth/logout">🚪 Wyloguj</a>
            </div>
        <% } %>
    </div>

    <h1>📅 Harmonogram dla sali: <%= room.name %></h1>
    <div class="room-info-bar">
        <span>📍 <strong>Lokalizacja:</strong> <%= room.location %></span>
        <span>👥 <strong>Pojemność:</strong> <%= room.capacity %> os.</span>
    </div>

    <div class="box">
        <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
            <div class="error-alert">
                <%= errorMessage %>
            </div>
        <% } %>

        <h3 style="margin-top: 0; margin-bottom: 5px; font-size: 1.1rem; font-weight: 600;">Zarezerwuj tę salę</h3>
        <p style="font-size: 0.82rem; color: var(--text-muted); margin-bottom: 20px; line-height: 1.4;">
            * Zasady rezerwacji: Sala dostępna w godzinach <strong>07:00 - 23:00</strong>. Czas trwania: <strong>od 1 do 12 godzin</strong>. Daty nie mogą nakładać się na inne spotkania.
        </p>
        
        <form action="/rooms/<%= room.id %>/reserve" method="POST">
            
            <% if (currentUser && currentUser.role === 'admin') { %>
                <div class="form-group">
                    <label for="targetUserId">Rezerwacja w imieniu pracownika:</label>
                    <select id="targetUserId" name="targetUserId" required>
                        <option value="">-- Wybierz pracownika z systemu --</option>
                        <% users.forEach(user => { %>
                            <option value="<%= user.id %>"><%= user.firstName %> <%= user.lastName %> (<%= user.email %>)</option>
                        <% }) %>
                    </select>
                </div>
            <% } %>

            <div class="form-group">
                <label for="title">Tytuł / Cel spotkania:</label>
                <input type="text" id="title" name="title" placeholder="np. Retro zespołu / Rozmowa rekrutacyjna" required>
            </div>
            <div class="form-group">
                <label for="startTime">Czas rozpoczęcia:</label>
                <input type="datetime-local" id="startTime" name="startTime" required>
            </div>
            <div class="form-group">
                <label for="endTime">Czas zakończenia:</label>
                <input type="datetime-local" id="endTime" name="endTime" required>
            </div>

            <button type="submit" class="btn-submit">
                <% if (currentUser && currentUser.role === 'admin') { %>
                    Zarezerwuj w imieniu pracownika
                <% } else { %>
                    Zarezerwuj termin
                <% } %>
            </button>
        </form>
    </div>

    <h2>Aktualne rezerwacje</h2>
    
    <% if (room.Reservations.length === 0) { %>
        <p style="color: var(--text-muted); font-style: italic;">Brak zaplanowanych spotkań dla tej sali. Bądź pierwszy!</p>
    <% } else { %>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Spotkanie</th>
                        <th>Od</th>
                        <th>Do</th>
                        <th>Rezerwujący</th>
                        <% if (currentUser && currentUser.role === 'admin') { %>
                            <th>Akcje</th>
                        <% } %>
                    </tr>
                </thead>
                <tbody>
                    <% room.Reservations.forEach(res => { %>
                        <tr>
                            <td><strong><%= res.title %></strong></td>
                            <td><%= new Date(res.startTime).toLocaleString('pl-PL') %></td>
                            <td><%= new Date(res.endTime).toLocaleString('pl-PL') %></td>
                            <td>👤 <%= res.User ? (res.User.firstName + ' ' + res.User.lastName) : 'Nieznany użytkownik' %></td>
                            
                            <% if (currentUser && currentUser.role === 'admin') { %>
                                <td>
                                    <div style="display: flex; gap: 8px;">
                                        <button type="button" class="btn-action-edit" 
                                                onclick="openEditReservationModal('<%= res.id %>', '<%= res.title %>', '<%= res.startTime %>', '<%= res.endTime %>', '<%= res.userId %>')">
                                            Edytuj
                                        </button>

                                        <form action="/reservations/<%= res.id %>/delete" method="POST" style="margin: 0;" id="delete-form-<%= res.id %>">
                                            <input type="hidden" name="reason" id="reason-<%= res.id %>">
                                            <button type="button" class="btn-action-delete" onclick="confirmDelete('<%= res.id %>', '<%= res.title %>')">
                                                Usuń
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            <% } %>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>

    <% if (currentUser && currentUser.role === 'admin') { %>
        <div id="editReservationModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.6); z-index: 1000; justify-content: center; align-items: center; backdrop-filter: blur(4px);">
            <div class="box" style="width: 90%; max-width: 480px; margin-bottom: 0;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h2 style="margin: 0; font-size: 1.25rem;">✏️ Edytuj Rezerwację</h2>
                    <button type="button" onclick="closeEditReservationModal()" style="width: auto; background: transparent; color: var(--text-muted); font-size: 1.5rem; padding: 0; border: none; cursor: pointer;">&times;</button>
                </div>
                
                <form id="editReservationForm" method="POST">
                    <div class="form-group">
                        <label for="edit_title">Tytuł / Cel spotkania:</label>
                        <input type="text" id="edit_title" name="title" required>
                    </div>
                    <div class="form-group">
                        <label for="edit_startTime">Czas rozpoczęcia:</label>
                        <input type="datetime-local" id="edit_startTime" name="startTime" required>
                    </div>
                    <div class="form-group">
                        <label for="edit_endTime">Czas zakończenia:</label>
                        <input type="datetime-local" id="edit_endTime" name="endTime" required>
                    </div>
                    <div class="form-group">
                        <label for="edit_targetUserId">Przypisany pracownik:</label>
                        <select id="edit_targetUserId" name="targetUserId" required>
                            <% users.forEach(user => { %>
                                <option value="<%= user.id %>"><%= user.firstName %> <%= user.lastName %> (<%= user.email %>)</option>
                            <% }) %>
                        </select>
                    </div>
                    
                    <button type="submit" class="btn-submit" style="background: var(--amber);">Zapisz zmiany</button>
                </form>
            </div>
        </div>
    <% } %>

    <script>
    function confirmDelete(resId, resTitle) {
        const reason = prompt(`⚠️ Czy na pewno chcesz usunąć rezerwację "${resTitle}"?\nPodaj powód usunięcia (wymagane):`);
        if (reason === null) return;
        if (reason.trim() === "") {
            alert("🛑 Usunięcie rezerwacji wymaga podania ważnego powodu!");
            return;
        }
        document.getElementById(`reason-${resId}`).value = reason;
        document.getElementById(`delete-form-${resId}`).submit();
    }

    const now = new Date();
    now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
    const currentDateTimeString = now.toISOString().slice(0, 16);
    
    document.getElementById('startTime').min = currentDateTimeString;
    document.getElementById('endTime').min = currentDateTimeString;

    function openEditReservationModal(id, title, startTime, endTime, userId) {
        document.getElementById('editReservationForm').action = `/reservations/${id}/edit`;
        
        document.getElementById('edit_title').value = title;
        document.getElementById('edit_targetUserId').value = userId;
        
        const formatToDateTimeLocal = (dateString) => {
            const d = new Date(dateString);
            d.setMinutes(d.getMinutes() - d.getTimezoneOffset());
            return d.toISOString().slice(0, 16);
        };
        
        document.getElementById('edit_startTime').value = formatToDateTimeLocal(startTime);
        document.getElementById('edit_endTime').value = formatToDateTimeLocal(endTime);
        
        document.getElementById('editReservationModal').style.display = 'flex';
    }

    function closeEditReservationModal() {
        document.getElementById('editReservationModal').style.display = 'none';
    }

    window.onclick = function(event) {
        const resModal = document.getElementById('editReservationModal');
        if (event.target === resModal) {
            closeEditReservationModal();
        }
    }
    </script>
</body>
</html>